# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ypgolzcibtjljfydxcun.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
# En prod : https://roullepro.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RoullePro

# Email (Resend - https://resend.com)
# Ajouter dans Netlify: Site settings > Environment variables
# Sans ces clés, les emails sont silencieusement ignorés
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Expéditeur vérifié sur Resend.
# Domaine racine `roullepro.com` est vérifié (SPF + DKIM OK) — utiliser un alias
# de ce domaine. Le sous-domaine `send.roullepro.com` n'est PAS vérifié sur
# Resend (essai abandonné), ne JAMAIS l'utiliser ici, tout envoi retournerait
# HTTP 403 "domain is not verified" et `sendEmail` swallow l'erreur sans Sentry.
# Si la variable n'est pas définie, fallback hardcodé sur onboarding@resend.dev
# (fonctionne mais image de marque dégradée + risque spam).
RESEND_FROM_EMAIL=RoullePro <notifications@roullepro.com>

# Email admin pour les notifications de modération
# Remplacer par l'email de l'administrateur RoullePro
ADMIN_EMAIL=lucas.horville@lvlia.net

# Email de secours pour les demandes de transport sans pro joignable (sinon ADMIN_EMAIL)
# DEMANDE_TRANSPORT_FALLBACK_EMAIL=contact@roullepro.com

# Secret HMAC pour les liens d'acceptation directe des demandes de transport (GAP4)
# Génère une valeur aléatoire forte : openssl rand -hex 32
# Sans cette clé, le bouton "Accepter cette course" n'est pas inclus dans l'email pro
DEMANDE_ACCEPT_SECRET=change_me_openssl_rand_hex_32

# hCaptcha (https://hcaptcha.com)
# Clés de test (fonctionnent en dev/staging, toujours valides)
# Remplacer par les vraies clés en production
NEXT_PUBLIC_HCAPTCHA_SITEKEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# Google Maps Places (autocomplete des lieux de transport)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
